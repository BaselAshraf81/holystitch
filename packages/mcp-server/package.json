{
  "name": "@stitch-to-react/mcp-server",
  "version": "0.1.0",
  "description": "MCP server that converts Stitch HTML screens into Next.js React projects",
  "main": "dist/index.js",
  "bin": {
    "stitch-to-react": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js mcp",
    "start:http": "node dist/index.js http",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@google/stitch-sdk": "^0.0.3",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-html-parser": "^6.1.13",
    "openai": "^4.80.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
